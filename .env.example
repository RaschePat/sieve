# 클라우드 LLM (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# 모델 설정 (생략 시 기본값 사용)
CLOUD_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-opus-4-8
LOCAL_MODEL=Qwen2.5-7B-Instruct-4bit

# 로컬 LLM 서버 (OpenAI 호환 엔드포인트)
# oMLX 기본값. LM Studio면 http://localhost:1234/v1, Ollama면 http://localhost:11434/v1
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_API_KEY=test123

# 로컬 모델 한국어 입력 시 중국어 혼용 방지 가드 (1=켜짐, 0=꺼짐)
LOCAL_KOREAN_GUARD=1

# 품질 검증(LLM-as-judge) 샘플링 비율 (0.0 ~ 1.0)
JUDGE_SAMPLE_RATE=0.1

# 라우팅 로그 DB 경로
ROUTER_DB_PATH=router.db
